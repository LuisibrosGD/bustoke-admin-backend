# ── Base de datos ──────────────────────────────────────────────────────────
# Conexión asíncrona a PostgreSQL (asyncpg)
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxxx.us-east-x.aws.neon.tech/neondb

# ── JWT ────────────────────────────────────────────────────────────────────
# Clave secreta para firmar tokens (cambiar en producción)
SECRET_KEY=change-this-secret-key-in-production
# Algoritmo de firma (HS256 recomendado)
ALGORITHM=HS256
# Tiempo de expiración del access token (minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Tiempo de expiración del refresh token (días)
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ───────────────────────────────────────────────────────────────────
# Orígenes permitidos separados por coma (ej: http://localhost:3000,https://admin.bustoke.pe)
CORS_ORIGINS=http://localhost:3000

# ── Servidor ───────────────────────────────────────────────────────────────
# Puerto donde corre uvicorn
PORT=5000

# ── Email (opcional) ───────────────────────────────────────────────────────
# Configuración SMTP para recovery de contraseña (TODO)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=SG.xxxxx
# EMAIL_FROM=noreply@bustoke.pe
